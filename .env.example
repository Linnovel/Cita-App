# Variables de entorno para la base de datos PostgreSQL
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=citaapp_db

# Secreto para la firma de tokens JWT (debe ser una cadena larga y aleatoria)
JWT_SECRET=un_secreto_seguro

# Nota: Las variables VITE_APP_CONTEXT para los frontends (admin/customer)
# se inyectan directamente en los scripts de build/dev de cada package.json
# usando 'cross-env', por lo que no necesitan estar aquí.